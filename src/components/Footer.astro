---
import EditLink from "virtual:starlight/components/EditLink";
import LastUpdated from "virtual:starlight/components/LastUpdated";
import Pagination from "virtual:starlight/components/Pagination";
import config from "virtual:starlight/user-config";
import { Icon } from "@astrojs/starlight/components";
---

<footer class="bs-doc-footer">
  <div class="bs-doc-footer__meta">
    <EditLink />
    <LastUpdated />
  </div>

  <Pagination />

  {
    config.credits && (
      <a class="bs-doc-footer__kudos" href="https://starlight.astro.build">
        <Icon name="starlight" /> {Astro.locals.t("builtWithStarlight.label")}
      </a>
    )
  }
</footer>

<style>
  @layer starlight.core {
    .bs-doc-footer {
      display: flex;
      flex-direction: column;
      gap: 1.35rem;
      margin-top: 3.4rem;
      padding-top: 1.1rem;
      border-top: 1px solid var(--sl-color-gray-6);
    }

    .bs-doc-footer__meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
      align-items: center;
      justify-content: space-between;
      color: var(--sl-color-gray-3);
      font-size: var(--sl-text-sm);
    }

    .bs-doc-footer__meta :global(a) {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      min-height: 2.05rem;
      padding: 0.2rem 0.55rem;
      border: 1px solid transparent;
      border-radius: 999px;
      color: var(--sl-color-gray-3);
      text-decoration: none;
      transition:
        border-color 160ms ease,
        color 160ms ease,
        background-color 160ms ease;
    }

    .bs-doc-footer__meta :global(a:hover) {
      border-color: color-mix(in srgb, var(--sl-color-accent) 34%, transparent);
      color: var(--sl-color-white);
      background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    }

    .bs-doc-footer__meta :global(p) {
      margin: 0;
      color: var(--sl-color-gray-3);
    }

    .bs-doc-footer__meta :global(time) {
      color: var(--sl-color-gray-2);
    }

    .bs-doc-footer__kudos {
      display: inline-flex;
      align-items: center;
      gap: 0.5em;
      width: fit-content;
      margin: 1.2rem auto;
      color: var(--sl-color-gray-3);
      font-size: var(--sl-text-xs);
      text-decoration: none;
    }

    .bs-doc-footer__kudos:hover {
      color: var(--sl-color-white);
    }

    .bs-doc-footer__kudos :global(svg) {
      color: var(--sl-color-orange);
    }
  }
</style>

---
const { dir, pagination } = Astro.locals.starlightRoute;
const { prev, next } = pagination;
const isRtl = dir === "rtl";

const leftArrow = isRtl
  ? "M9 5l7 7-7 7M16 12H4"
  : "M15 5l-7 7 7 7M8 12h12";
const rightArrow = isRtl
  ? "M15 5l-7 7 7 7M8 12h12"
  : "M9 5l7 7-7 7M16 12H4";
---

<nav class="bs-pagination print:hidden" dir={dir} aria-label="Page navigation">
  {
    prev && (
      <a class="bs-pagination-card is-prev" href={prev.href} rel="prev">
        <span class="bs-pagination-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d={leftArrow} />
          </svg>
        </span>
        <span class="bs-pagination-copy">
          <span class="bs-pagination-kicker">{Astro.locals.t("page.previousLink")}</span>
          <span class="bs-pagination-title">{prev.label}</span>
        </span>
      </a>
    )
  }
  {
    next && (
      <a class="bs-pagination-card is-next" href={next.href} rel="next">
        <span class="bs-pagination-copy">
          <span class="bs-pagination-kicker">{Astro.locals.t("page.nextLink")}</span>
          <span class="bs-pagination-title">{next.label}</span>
        </span>
        <span class="bs-pagination-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none">
            <path d={rightArrow} />
          </svg>
        </span>
      </a>
    )
  }
</nav>

<style>
  @layer starlight.core {
    .bs-pagination {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(min(19rem, 100%), 1fr));
      gap: 1rem;
    }

    .bs-pagination-card {
      position: relative;
      display: grid;
      grid-template-columns: auto minmax(0, 1fr);
      gap: 0.85rem;
      align-items: center;
      min-height: 7.25rem;
      overflow: hidden;
      padding: 1.05rem;
      border: 1px solid transparent;
      border-radius: 10px;
      color: var(--sl-color-gray-2);
      text-decoration: none;
      background:
        linear-gradient(var(--sl-color-bg), var(--sl-color-bg)) padding-box,
        linear-gradient(
          135deg,
          color-mix(in srgb, var(--sl-color-accent) 48%, transparent),
          color-mix(in srgb, #67e8f9 24%, transparent),
          color-mix(in srgb, var(--sl-color-gray-5) 78%, transparent)
        ) border-box;
      box-shadow:
        0 18px 54px color-mix(in srgb, var(--sl-color-accent) 9%, transparent),
        inset 0 1px 0 rgba(255, 255, 255, 0.035);
      transition:
        border-color 160ms ease,
        color 160ms ease,
        transform 160ms ease;
    }

    .bs-pagination-card::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(90deg, color-mix(in srgb, var(--sl-color-accent) 10%, transparent), transparent 42%),
        linear-gradient(90deg, rgba(255, 255, 255, 0.028) 1px, transparent 1px);
      background-size: auto, 28px 100%;
      opacity: 0.82;
    }

    .bs-pagination-card:hover {
      color: var(--sl-color-white);
      transform: translateY(-1px);
    }

    .bs-pagination-card:hover .bs-pagination-icon {
      border-color: color-mix(in srgb, var(--sl-color-accent) 76%, transparent);
      color: var(--sl-color-accent-high);
      background: color-mix(in srgb, var(--sl-color-accent) 18%, transparent);
    }

    .bs-pagination-card.is-next {
      grid-template-columns: minmax(0, 1fr) auto;
      text-align: end;
    }

    .bs-pagination-copy,
    .bs-pagination-icon {
      position: relative;
      z-index: 1;
    }

    .bs-pagination-copy {
      display: grid;
      min-width: 0;
      gap: 0.3rem;
    }

    .bs-pagination-kicker {
      color: var(--sl-color-gray-3);
      font-size: 0.76rem;
      font-weight: 850;
      line-height: 1;
      text-transform: uppercase;
      letter-spacing: 0;
    }

    .bs-pagination-title {
      min-width: 0;
      color: var(--sl-color-white);
      font-size: clamp(1.1rem, 3vw, 1.55rem);
      font-weight: 850;
      line-height: 1.12;
      overflow-wrap: anywhere;
    }

    .bs-pagination-icon {
      display: grid;
      place-items: center;
      width: 2.3rem;
      height: 2.3rem;
      border: 1px solid var(--sl-color-gray-5);
      border-radius: 8px;
      color: var(--sl-color-gray-3);
      background: rgba(255, 255, 255, 0.025);
      transition:
        border-color 160ms ease,
        color 160ms ease,
        background-color 160ms ease;
    }

    .bs-pagination-icon svg {
      width: 1.1rem;
      height: 1.1rem;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    @media (max-width: 640px) {
      .bs-pagination-card,
      .bs-pagination-card.is-next {
        grid-template-columns: auto minmax(0, 1fr);
        text-align: start;
      }

      .bs-pagination-card.is-next .bs-pagination-copy {
        order: 2;
      }

      .bs-pagination-card.is-next .bs-pagination-icon {
        order: 1;
      }
    }
  }
</style>
